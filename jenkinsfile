pipeline{

    agent any

    stages{

        stage("continuous download") {

            steps{
                git branch: 'main', url: 'https://github.com/njokadeclan/JENKS-PROJECT1.git'
            }
        }
        stage("unit test") {

            steps{
                sh'mvn test'
            }
        }
        stage("integration test"){

            steps{
                sh'mvn verify -DskipUnitTests'
            }
        }
        stage("continuous build") {

            steps{
                sh'mvn clean install'
            }
        }
        stage("static test analysis") {

            steps{

                script{
                     withSonarQubeEnv(credentialsId: 'sonar-link') {
                        sh 'mvn clean package sonar:sonar'
                     }
                }
            }
        }
        stage("quality gate analysis") {

            steps{

                script{
                  waitForQualityGate abortPipeline: false, credentialsId: 'sonar-link'  
                }
            }
        }
        stage("uplaod artifact to nexus"){

            steps{

                script{
                  nexusArtifactUploader artifacts: [[artifactId: 'springboot', classifier: '', file: 'target/Uber.jar', type: 'jar']], credentialsId: 'nexus-jenks', groupId: 'com.example', nexusUrl: '18.222.138.157:8081', nexusVersion: 'nexus3', protocol: 'http', repository: 'jenks-project', version: '1.0.0'  
                }
            }
        }
        stage("Docker Build"){

            steps{

                script{
                    sh 'docker build -t myuber .'
                    sh 'docker tag myuber:latest njokadeclan/jenks-project1:my-first-project-image'
                }
            }
        }
    }
}